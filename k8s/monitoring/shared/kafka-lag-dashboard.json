{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "title": "Kafka Consumer Lag (Max)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "kafka_consumer_fetch_manager_records_lag_max{application=~\"$application\"}",
          "legendFormat": "{{client_id}} — {{topic}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "red", "value": 100 }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "title": "Records Consumed Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "rate(kafka_consumer_fetch_manager_records_consumed_total{application=~\"$application\"}[5m])",
          "legendFormat": "{{client_id}} — {{topic}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ops" },
        "overrides": []
      }
    },
    {
      "title": "Consumer Fetch Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "rate(kafka_consumer_fetch_manager_fetch_total{application=~\"$application\"}[5m])",
          "legendFormat": "{{client_id}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ops" },
        "overrides": []
      }
    }
  ],
  "schemaVersion": 39,
  "tags": ["peekcart", "kafka"],
  "templating": {
    "list": [
      {
        "name": "application",
        "label": "Application",
        "type": "custom",
        "query": "notification-service,order-service,payment-service,product-service,user-service",
        "multi": true,
        "includeAll": true,
        "allValue": ".*",
        "current": { "text": ["All"], "value": ["$__all"] },
        "options": [
          { "text": "All", "value": "$__all", "selected": true },
          { "text": "notification-service", "value": "notification-service", "selected": false },
          { "text": "order-service", "value": "order-service", "selected": false },
          { "text": "payment-service", "value": "payment-service", "selected": false },
          { "text": "product-service", "value": "product-service", "selected": false },
          { "text": "user-service", "value": "user-service", "selected": false }
        ],
        "hide": 0
      }
    ]
  },
  "time": { "from": "now-30m", "to": "now" },
  "title": "PeekCart — Kafka Consumer Lag",
  "uid": "peekcart-kafka-lag"
}
